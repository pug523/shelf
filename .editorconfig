root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 2

[*.java]
indent_size = 4

[*.{vsh,fsh,vert,frag,glsl}]
indent_size = 2

[*.py]
indent_size = 4
# black formatter
max_line_length = 88

[*.md]
# double whitespace at end of line
# denotes a line break in Markdown
trim_trailing_whitespace = false

[*.{toml,yaml,yml,json}]
indent_style = space
indent_size = 2

