{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "",
  "authors": ["pugur"],
  "contact": {
    "sources": "https://github.com/pug523/shelf",
    "issues": "https://github.com/pug523/shelf/issues"
  },
  "license": "Apache-2.0",
  "icon": "assets/shelf/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.pug523.shelf.Shelf"
    ],
    "modmenu": [
      "com.pug523.shelf.common.compat.modmenu.ModMenuApiImpl"
    ]
  },
  "mixins": [
    "shelf.mixins.json"
  ],
  "accessWidener": "shelf.accesswidener",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "${command_api}": ">=${fabric_api_version}",
    "${rendering_api}": ">=${fabric_api_version}",
    "minecraft": "${minecraft_dependency}"
  },
  "suggests": {
    "modmenu": "*"
